{
  "name": "@labcabrera-rmu/rmu-react-shared-lib",
  "version": "0.1.2",
  "private": false,
  "description": "RMU React Shared Library",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
     "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prepublishOnly": "npm run build",
    "postinstall": "echo '{\"type\":\"module\",\"sideEffects\":false,\"version\":\"7.3.1\"}' > node_modules/@mui/material/esm/package.json && echo '{\"type\":\"module\",\"sideEffects\":false,\"version\":\"7.3.1\"}' > node_modules/@mui/icons-material/esm/package.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/labcabrera/rmu-react-shared-lib"
  },
  "keywords": [
    "RMU",
    "React",
    "Shared Library"
  ],
  "author": "lab.cabrera@gmail.com",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/labcabrera/rmu-react-shared-lib/issues"
  },
  "homepage": "https://github.com/labcabrera/rmu-react-shared-lib#readme",
  "dependencies": {
    "@babel/runtime": "^7.28.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.6",
    "@mui/icons-material": "^7.3.1",
    "@mui/lab": "^7.0.0-beta.14",
    "@mui/material": "^7.3.1",
    "@mui/x-data-grid": "^8.9.2",
    "file-loader": "^6.2.0",
    "i18next": "^25.3.2",
    "react": "^19.1.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.0.2",
    "react-router-dom": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.9.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.2",
    "prettier": "^3.8.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
